# CodeHub OAuth Credentials
# Copy this file to .env and fill in your own values
# NEVER commit your actual .env file to the repository

CLIENT_ID=your_github_oauth_client_id_here
CLIENT_SECRET=your_github_oauth_client_secret_here

# Note: For extension testing, you must also update the hardcoded values in:
# - src/js/authorize.js
# - src/js/oauth2.js