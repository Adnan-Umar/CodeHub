{
  "name": "codehub",
  "version": "0.0.16",
  "type": "module",
  "private": true,
  "description": "Automatically sync coding solutions from LeetCode, HackerRank, GeeksForGeeks, and more to GitHub",
  "scripts": {
    "setup": "npm i",
    "format": "prettier --write src/**/*.{js,jsx,ts,tsx,css,html}",
    "format-test": "prettier --check src/**/*.{js,jsx,ts,tsx,css,html}",
    "lint": "eslint . --fix --ignore-pattern 'src/js/static/jquery-3.3.1.min.js' --ignore-pattern 'src/js/static/semantic-2.4.1.min.js'"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4"
  }
}
